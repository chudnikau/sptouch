  object tdbAllParams: TZReadOnlyQuery
    Connection = DM.MySQLConnection
    SQL.Strings = (
      'SELECT'
      '   paramsqueries.paramquery_id,'
      '   paramsqueries.name paramsqueries_name,'
      '   meters.name meter_name,'
      '   params.spparam,'
      '   params.canal,'
      '   params.description,'
      
        '   IF(paramsqueries.enabled > 0, '#39#1054#1087#1088#1072#1096#1080#1074#1072#1077#1090#1089#1103#39', '#39#1053#1077' '#1086#1087#1088#1072#1096#1080#1074#1072#1077#1090#1089 +
        #1103#39') paramQueryState'
      'FROM paramsqueries'
      'INNER JOIN meters ON meters.meter_id = paramsqueries.meter_id'
      'INNER JOIN params ON params.param_id = paramsqueries.param_id'
      'WHERE paramsqueries.paramquery_id'
      '  NOT IN  (SELECT paramquery_id FROM paramsanaloggroup'
      '      WHERE paramsanaloggroup.analoggroup_id = :analoggroup_id)'
      'AND paramsqueries.array_id IS NULL')
    Params = <
      item
        DataType = ftUnknown
        Name = 'analoggroup_id'
        ParamType = ptUnknown
      end>
    DataSource = dtsdtbanaloggroups
    Left = 120
    Top = 102
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'analoggroup_id'
        ParamType = ptUnknown
      end>
