  object dtbparamsanaloggroup: TZQuery
    Connection = DM.MySQLConnection
    AfterOpen = dtbparamsanaloggroupAfterOpen
    AfterRefresh = dtbparamsanaloggroupAfterRefresh
    SQL.Strings = (
      'SELECT'
      'paramsqueries.paramquery_id,'
      'paramsqueries.name,'
      'paramsanaloggroup.color'
      'FROM paramsqueries'
      
        'INNER JOIN paramsanaloggroup ON paramsanaloggroup.paramquery_id ' +
        '= paramsqueries.paramquery_id'
      'WHERE paramsanaloggroup.analoggroup_id = :analoggroup_id')
