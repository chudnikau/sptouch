  object dtbParamsAnalogGroup: TZQuery
    Connection = DM.MySQLConnection
    SQL.Strings = (
      
        'SELECT analoggroup_id, paramquery_id, lvalue, svalue, hvalue, co' +
        'lor FROM paramsanaloggroup WHERE '
      'analoggroup_id = :analoggroup_id AND'
      'paramquery_id = :paramquery_id')
    Params = <
      item
        DataType = ftUnknown
        Name = 'analoggroup_id'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'paramquery_id'
        ParamType = ptUnknown
      end>
    Left = 40
    Top = 128
