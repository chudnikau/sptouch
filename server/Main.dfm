  object dtsparamsqueries: TDataSource
    DataSet = dtbparamsqueries
    Left = 304
    Top = 104
  end
  object dtbparamsqueries: TZReadOnlyQuery
    AfterOpen = dtbparamsqueriesAfterOpen
    SQL.Strings = (
      'SELECT'
      '  paramsqueries.paramquery_id,'
      '  paramsqueries.name paramquery_name,'
      '  params.canal,'
      '  params.description,'
      '  IF(meters.enabled > 0, paramsqueries.value, 0) value,'
      '  unitsparams.unitSN'
      'FROM paramsqueries'
      'INNER JOIN params ON params.param_id = paramsqueries.param_id'
      'INNER JOIN meters ON meters.meter_id = paramsqueries.meter_id'
      
        'LEFT JOIN unitsparams ON unitsparams.unitparam_id = paramsquerie' +
        's.unitparam_id'
      
        'WHERE paramsqueries.meter_id = :meter_id AND paramsqueries.enabl' +
        'ed > 0 ORDER BY params.spparam, params.canal')
    Params = <
      item
        DataType = ftUnknown
        Name = 'meter_id'
        ParamType = ptUnknown
      end>
    Left = 336
    Top = 104
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'meter_id'
        ParamType = ptUnknown
      end>
